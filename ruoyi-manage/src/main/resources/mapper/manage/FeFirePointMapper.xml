<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ruoyi.manage.mapper.FeFirePointMapper">

    <resultMap id="FeFirePointResult" type="FeFirePoint">
        <result property="firePointId" column="fire_point_id" />
        <result property="externalStationId" column="external_station_id" />
        <result property="firePointCode" column="fire_point_code" />
        <result property="firePointName" column="fire_point_name" />
        <result property="stationNumber" column="station_number" />
        <result property="stationType" column="station_type" />
        <result property="externalCompanyId" column="external_company_id" />
        <result property="externalCompanyName" column="external_company_name" />
        <result property="sourceDeptId" column="source_dept_id" />
        <result property="sourceDeptName" column="source_dept_name" />
        <result property="deptId" column="dept_id" />
        <result property="deptName" column="dept_name" />
        <result property="deptProvince" column="dept_province" />
        <result property="deptCity" column="dept_city" />
        <result property="deptArea" column="dept_area" />
        <result property="pointType" column="point_type" />
        <result property="location" column="location" />
        <result property="floor" column="floor" />
