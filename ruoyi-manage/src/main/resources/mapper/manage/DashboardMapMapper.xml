<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ruoyi.manage.mapper.DashboardMapMapper">

    <resultMap id="DashboardMapFirePointResult" type="com.ruoyi.manage.domain.dashboard.DashboardMapFirePoint">
        <result property="firePointId" column="fire_point_id" />
        <result property="firePointName" column="fire_point_name" />
        <result property="location" column="location" />
        <result property="building" column="building" />
        <result property="floor" column="floor" />
        <result property="longitude" column="longitude" />
        <result property="latitude" column="latitude" />
        <result property="deptId" column="dept_id" />
        <result property="deptName" column="dept_name" />
        <result property="resolvedDeptId" column="resolved_dept_id" />
        <result property="resolvedDeptName" column="resolved_dept_name" />
        <result property="externalCompanyId" column="external_company_id" />
        <result property="externalCompanyName" column="external_company_name" />
        <result property="contactPerson" column="contact_person" />
        <result property="contactPhone" column="contact_phone" />
        <result property="status" column="status" />
    </resultMap>

    <select id="selectFirePointsForMap" resultMap="DashboardMapFirePointResult">
        select f.fire_point_id,
               f.fire_point_name,
               f.location,
               f.building,
               f.floor,
               f.longitude,
               f.latitude,
               f.dept_id,
               d.dept_name,
               coalesce(f.dept_id, m.dept_id, pm.dept_id, f.source_dept_id) as resolved_dept_id,
               rd.dept_name as resolved_dept_name,
               f.external_company_id,
               ec.external_company_name,
               f.contact_person,
               f.contact_phone,
               f.status
        from fe_fire_point f
        left join sys_dept d on f.dept_id = d.dept_id
        left join fe_external_company ec on f.external_company_id = ec.external_company_id
        left join fe_company_dept_mapping m on f.external_company_id = m.external_company_id
        left join fe_company_dept_mapping pm on ec.parent_external_company_id = pm.external_company_id
        left join sys_dept rd on coalesce(f.dept_id, m.dept_id, pm.dept_id, f.source_dept_id) = rd.dept_id
        where f.del_flag = '0'
        <if test="deptIds != null and deptIds.size() > 0">
            and (
                f.dept_id in
                <foreach collection="deptIds" item="deptId" open="(" separator="," close=")">
                    #{deptId}
                </foreach>
                or m.dept_id in
                <foreach collection="deptIds" item="deptId" open="(" separator="," close=")">
                    #{deptId}
                </foreach>
                or pm.dept_id in
                <foreach collection="deptIds" item="deptId" open="(" separator="," close=")">
                    #{deptId}
                </foreach>
                or f.source_dept_id in
                <foreach collection="deptIds" item="deptId" open="(" separator="," close=")">
                    #{deptId}
                </foreach>
            )
        </if>
        order by resolved_dept_id, f.fire_point_id
    </select>
</mapper>
