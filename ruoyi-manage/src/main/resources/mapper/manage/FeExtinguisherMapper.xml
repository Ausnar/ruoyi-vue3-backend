<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ruoyi.manage.mapper.FeExtinguisherMapper">

    <resultMap id="FeExtinguisherResult" type="FeExtinguisher">
        <result property="extinguisherId" column="extinguisher_id" />
        <result property="externalExtinguisherId" column="external_extinguisher_id" />
        <result property="externalCompanyId" column="external_company_id" />
        <result property="labelCode" column="label_code" />
        <result property="specification" column="specification" />
        <result property="sensorId" column="sensor_id" />
        <result property="sensorCode" column="sensor_code" />
        <result property="deptId" column="dept_id" />
        <result property="deptName" column="dept_name" />
        <result property="sourceDeptId" column="source_dept_id" />
        <result property="sourceDeptName" column="source_dept_name" />
        <result property="externalCompanyName" column="external_company_name" />
        <result property="productName" column="product_name" />
        <result property="manufacturer" column="manufacturer" />
        <result property="serviceProvider" column="service_provider" />
        <result property="productionDate" column="production_date" />
        <result property="inspectionDate" column="inspection_date" />
        <result property="expiryDate" column="expiry_date" />
        <result property="scrapDate" column="scrap_date" />
        <result property="firePointId" column="fire_point_id" />
        <result property="installLocation" column="install_location" />
        <result property="qrCode" column="qr_code" />
        <result property="status" column="status" />
        <result property="syncStatus" column="sync_status" />
        <result property="lastSyncTime" column="last_sync_time" />
        <result property="createBy" column="create_by" />
        <result property="createTime" column="create_time" />
        <result property="updateBy" column="update_by" />
        <result property="updateTime" column="update_time" />
        <result property="remark" column="remark" />
        <result property="delFlag" column="del_flag" />
    </resultMap>

    <sql id="selectFeExtinguisherVo">
        select e.extinguisher_id, e.external_extinguisher_id, e.external_company_id, e.label_code,
               e.specification, e.sensor_id, e.sensor_code, e.dept_id, d.dept_name,
               e.source_dept_id, sd.dept_name as source_dept_name, ec.external_company_name, e.product_name, e.manufacturer,
               e.service_provider, e.production_date, e.inspection_date, e.expiry_date, e.scrap_date,
               e.fire_point_id, e.install_location, e.qr_code, e.status, e.sync_status, e.last_sync_time,
               e.create_by, e.create_time, e.update_by, e.update_time, e.remark, e.del_flag
        from fe_extinguisher e
        left join fe_external_company ec on e.external_company_id = ec.external_company_id
        left join sys_dept d on e.dept_id = d.dept_id
        left join sys_dept sd on e.source_dept_id = sd.dept_id
    </sql>

    <select id="selectFeExtinguisherList" parameterType="FeExtinguisher" resultMap="FeExtinguisherResult">
        <include refid="selectFeExtinguisherVo"/>
        <where>
            <if test="labelCode != null and labelCode != ''"> and e.label_code = #{labelCode}</if>
            <if test="externalExtinguisherId != null"> and e.external_extinguisher_id = #{externalExtinguisherId}</if>
            <if test="externalCompanyId != null"> and e.external_company_id = #{externalCompanyId}</if>
            <if test="sensorId != null"> and e.sensor_id = #{sensorId}</if>
            <if test="sensorCode != null and sensorCode != ''"> and e.sensor_code = #{sensorCode}</if>
            <if test="deptId != null"> and e.dept_id = #{deptId}</if>
            <if test="sourceDeptId != null"> and e.source_dept_id = #{sourceDeptId}</if>
            <if test="productName != null and productName != ''"> and e.product_name like concat('%', #{productName}, '%')</if>
            <if test="firePointId != null"> and e.fire_point_id = #{firePointId}</if>
            <if test="status != null and status != ''"> and e.status = #{status}</if>
            <if test="syncStatus != null and syncStatus != ''"> and e.sync_status = #{syncStatus}</if>
            ${params.dataScope}
        </where>
    </select>

    <select id="selectFeExtinguisherByExtinguisherId" parameterType="Long" resultMap="FeExtinguisherResult">
        <include refid="selectFeExtinguisherVo"/>
        where e.extinguisher_id = #{extinguisherId}
    </select>

    <select id="selectByExternalExtinguisherId" parameterType="Long" resultMap="FeExtinguisherResult">
        <include refid="selectFeExtinguisherVo"/>
        where e.external_extinguisher_id = #{externalExtinguisherId}
        limit 1
    </select>

    <select id="selectByLabelCode" parameterType="String" resultMap="FeExtinguisherResult">
        <include refid="selectFeExtinguisherVo"/>
        where e.label_code = #{labelCode}
        limit 1
    </select>

    <insert id="insertFeExtinguisher" parameterType="FeExtinguisher" useGeneratedKeys="true" keyProperty="extinguisherId">
        insert into fe_extinguisher
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="externalExtinguisherId != null">external_extinguisher_id,</if>
            <if test="externalCompanyId != null">external_company_id,</if>
            <if test="labelCode != null and labelCode != ''">label_code,</if>
            <if test="specification != null">specification,</if>
            <if test="sensorId != null">sensor_id,</if>
            <if test="sensorCode != null">sensor_code,</if>
            <if test="deptId != null">dept_id,</if>
            <if test="sourceDeptId != null">source_dept_id,</if>
            <if test="productName != null">product_name,</if>
            <if test="manufacturer != null">manufacturer,</if>
            <if test="serviceProvider != null">service_provider,</if>
            <if test="productionDate != null">production_date,</if>
            <if test="inspectionDate != null">inspection_date,</if>
            <if test="expiryDate != null">expiry_date,</if>
            <if test="scrapDate != null">scrap_date,</if>
            <if test="firePointId != null">fire_point_id,</if>
            <if test="installLocation != null">install_location,</if>
            <if test="qrCode != null">qr_code,</if>
            <if test="status != null">status,</if>
            <if test="syncStatus != null">sync_status,</if>
            <if test="lastSyncTime != null">last_sync_time,</if>
            <if test="createBy != null">create_by,</if>
            <if test="createTime != null">create_time,</if>
            <if test="updateBy != null">update_by,</if>
            <if test="updateTime != null">update_time,</if>
            <if test="remark != null">remark,</if>
            <if test="delFlag != null">del_flag,</if>
         </trim>
        <trim prefix="values (" suffix=")" suffixOverrides=",">
            <if test="externalExtinguisherId != null">#{externalExtinguisherId},</if>
            <if test="externalCompanyId != null">#{externalCompanyId},</if>
            <if test="labelCode != null and labelCode != ''">#{labelCode},</if>
            <if test="specification != null">#{specification},</if>
            <if test="sensorId != null">#{sensorId},</if>
            <if test="sensorCode != null">#{sensorCode},</if>
            <if test="deptId != null">#{deptId},</if>
            <if test="sourceDeptId != null">#{sourceDeptId},</if>
            <if test="productName != null">#{productName},</if>
            <if test="manufacturer != null">#{manufacturer},</if>
            <if test="serviceProvider != null">#{serviceProvider},</if>
            <if test="productionDate != null">#{productionDate},</if>
            <if test="inspectionDate != null">#{inspectionDate},</if>
            <if test="expiryDate != null">#{expiryDate},</if>
            <if test="scrapDate != null">#{scrapDate},</if>
            <if test="firePointId != null">#{firePointId},</if>
            <if test="installLocation != null">#{installLocation},</if>
            <if test="qrCode != null">#{qrCode},</if>
            <if test="status != null">#{status},</if>
            <if test="syncStatus != null">#{syncStatus},</if>
            <if test="lastSyncTime != null">#{lastSyncTime},</if>
            <if test="createBy != null">#{createBy},</if>
            <if test="createTime != null">#{createTime},</if>
            <if test="updateBy != null">#{updateBy},</if>
            <if test="updateTime != null">#{updateTime},</if>
            <if test="remark != null">#{remark},</if>
            <if test="delFlag != null">#{delFlag},</if>
         </trim>
    </insert>

    <update id="updateFeExtinguisher" parameterType="FeExtinguisher">
        update fe_extinguisher
        <trim prefix="SET" suffixOverrides=",">
            <if test="externalExtinguisherId != null">external_extinguisher_id = #{externalExtinguisherId},</if>
            <if test="externalCompanyId != null">external_company_id = #{externalCompanyId},</if>
            <if test="labelCode != null and labelCode != ''">label_code = #{labelCode},</if>
            <if test="specification != null">specification = #{specification},</if>
            <if test="sensorId != null">sensor_id = #{sensorId},</if>
            <if test="sensorCode != null">sensor_code = #{sensorCode},</if>
            <if test="deptId != null">dept_id = #{deptId},</if>
            <if test="sourceDeptId != null">source_dept_id = #{sourceDeptId},</if>
            <if test="productName != null">product_name = #{productName},</if>
            <if test="manufacturer != null">manufacturer = #{manufacturer},</if>
            <if test="serviceProvider != null">service_provider = #{serviceProvider},</if>
            <if test="productionDate != null">production_date = #{productionDate},</if>
            <if test="inspectionDate != null">inspection_date = #{inspectionDate},</if>
            <if test="expiryDate != null">expiry_date = #{expiryDate},</if>
            <if test="scrapDate != null">scrap_date = #{scrapDate},</if>
            <if test="firePointId != null">fire_point_id = #{firePointId},</if>
            <if test="installLocation != null">install_location = #{installLocation},</if>
            <if test="qrCode != null">qr_code = #{qrCode},</if>
            <if test="status != null">status = #{status},</if>
            <if test="syncStatus != null">sync_status = #{syncStatus},</if>
            <if test="lastSyncTime != null">last_sync_time = #{lastSyncTime},</if>
            <if test="updateBy != null">update_by = #{updateBy},</if>
            <if test="updateTime != null">update_time = #{updateTime},</if>
            <if test="remark != null">remark = #{remark},</if>
            <if test="delFlag != null">del_flag = #{delFlag},</if>
        </trim>
        where extinguisher_id = #{extinguisherId}
    </update>

    <update id="updateDeptIdByExternalCompanyId">
        update fe_extinguisher
        set dept_id = #{deptId,jdbcType=BIGINT}
        where external_company_id = #{externalCompanyId}
    </update>

    <delete id="deleteFeExtinguisherByExtinguisherId" parameterType="Long">
        delete from fe_extinguisher where extinguisher_id = #{extinguisherId}
    </delete>

    <delete id="deleteFeExtinguisherByExtinguisherIds" parameterType="String">
        delete from fe_extinguisher where extinguisher_id in
        <foreach item="extinguisherId" collection="array" open="(" separator="," close=")">
            #{extinguisherId}
        </foreach>
    </delete>
</mapper>
