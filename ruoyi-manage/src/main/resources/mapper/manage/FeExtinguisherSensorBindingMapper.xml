<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ruoyi.manage.mapper.FeExtinguisherSensorBindingMapper">

    <resultMap id="FeExtinguisherSensorBindingResult" type="FeExtinguisherSensorBinding">
        <result property="bindingId" column="binding_id" />
        <result property="extinguisherId" column="extinguisher_id" />
        <result property="sensorId" column="sensor_id" />
        <result property="externalExtinguisherId" column="external_extinguisher_id" />
        <result property="externalSensorId" column="external_sensor_id" />
        <result property="bindTime" column="bind_time" />
        <result property="unbindTime" column="unbind_time" />
        <result property="isActive" column="is_active" />
        <result property="sourceType" column="source_type" />
        <result property="remark" column="remark" />
        <result property="createBy" column="create_by" />
        <result property="createTime" column="create_time" />
        <result property="updateBy" column="update_by" />
        <result property="updateTime" column="update_time" />
    </resultMap>

    <sql id="selectFeExtinguisherSensorBindingVo">
        select binding_id, extinguisher_id, sensor_id, external_extinguisher_id, external_sensor_id,
               bind_time, unbind_time, is_active, source_type, remark, create_by, create_time, update_by, update_time
        from fe_extinguisher_sensor_binding
    </sql>

    <select id="selectBindingsByExtinguisherId" parameterType="Long" resultMap="FeExtinguisherSensorBindingResult">
        <include refid="selectFeExtinguisherSensorBindingVo"/>
        where extinguisher_id = #{extinguisherId}
        order by bind_time desc, binding_id desc
    </select>

    <select id="selectActiveBindingByExtinguisherId" parameterType="Long" resultMap="FeExtinguisherSensorBindingResult">
        <include refid="selectFeExtinguisherSensorBindingVo"/>
        where extinguisher_id = #{extinguisherId}
          and is_active = '1'
        order by bind_time desc, binding_id desc
        limit 1
    </select>

    <select id="selectByExtinguisherSensorAndBindTime" resultMap="FeExtinguisherSensorBindingResult">
        <include refid="selectFeExtinguisherSensorBindingVo"/>
        where extinguisher_id = #{extinguisherId}
          and sensor_id = #{sensorId}
          and bind_time = #{bindTime}
        limit 1
    </select>

    <insert id="insertFeExtinguisherSensorBinding" parameterType="FeExtinguisherSensorBinding" useGeneratedKeys="true" keyProperty="bindingId">
        insert into fe_extinguisher_sensor_binding
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="extinguisherId != null">extinguisher_id,</if>
            <if test="sensorId != null">sensor_id,</if>
            <if test="externalExtinguisherId != null">external_extinguisher_id,</if>
            <if test="externalSensorId != null">external_sensor_id,</if>
            <if test="bindTime != null">bind_time,</if>
            <if test="unbindTime != null">unbind_time,</if>
            <if test="isActive != null">is_active,</if>
            <if test="sourceType != null">source_type,</if>
            <if test="remark != null">remark,</if>
            <if test="createBy != null">create_by,</if>
            <if test="createTime != null">create_time,</if>
            <if test="updateBy != null">update_by,</if>
            <if test="updateTime != null">update_time,</if>
        </trim>
        <trim prefix="values (" suffix=")" suffixOverrides=",">
            <if test="extinguisherId != null">#{extinguisherId},</if>
            <if test="sensorId != null">#{sensorId},</if>
            <if test="externalExtinguisherId != null">#{externalExtinguisherId},</if>
            <if test="externalSensorId != null">#{externalSensorId},</if>
            <if test="bindTime != null">#{bindTime},</if>
            <if test="unbindTime != null">#{unbindTime},</if>
            <if test="isActive != null">#{isActive},</if>
            <if test="sourceType != null">#{sourceType},</if>
            <if test="remark != null">#{remark},</if>
            <if test="createBy != null">#{createBy},</if>
            <if test="createTime != null">#{createTime},</if>
            <if test="updateBy != null">#{updateBy},</if>
            <if test="updateTime != null">#{updateTime},</if>
        </trim>
    </insert>

    <update id="deactivateActiveBinding">
        update fe_extinguisher_sensor_binding
        set is_active = '0',
            unbind_time = #{unbindTime},
            update_by = #{updateBy},
            update_time = now()
        where extinguisher_id = #{extinguisherId}
          and is_active = '1'
    </update>
</mapper>
